generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  admin
  staff
}

model AllowedUser {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  role      Role     @default(staff)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("allowed_users")
}

model Profile {
  userId    String   @id @db.Uuid @map("user_id")
  email     String
  role      Role     @default(staff)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("profiles")
}

model Video {
  id           String   @id @default(uuid()) @db.Uuid
  bunnyVideoId String   @map("bunny_video_id")
  title        String
  category     String
  createdAt    DateTime @default(now()) @map("created_at")
  uploadedBy   String   @db.Uuid @map("uploaded_by")

  @@index([category])
  @@index([createdAt])
  @@map("videos")
}

model Todo {
  id        Int      @id @default(autoincrement())
  title     String
  createdAt DateTime @default(now())
}
